// UBAH MENJADI .env JIKA INGIN MENJALANKAN LOKAL
APP_NAME="Masjid Agung Gresik"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
# Tutorial SMTP Gmail Laravel (Indonesia): https://www.youtube.com/results?search_query=tutorial+smtp+gmail+laravel+indonesia
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="admin@masjidagunggresik.com"
MAIL_FROM_NAME="${APP_NAME}"

# Tutorial Integrasi Midtrans Laravel (Indonesia): https://www.youtube.com/results?search_query=tutorial+midtrans+laravel+indonesia
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# Tutorial Google Login/Socialite Laravel (Indonesia): https://www.youtube.com/results?search_query=tutorial+login+google+laravel+socialite+indonesia
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback